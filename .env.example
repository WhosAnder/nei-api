# ─── Railway PostgreSQL ────────────────────────────────────────────────────────
# Railway inyecta DATABASE_URL automáticamente en producción y staging.
# Para desarrollo local usa DATABASE_PUBLIC_URL (requiere exponer el puerto en Railway).
#
# En producción/staging Railway inyecta estas variables automáticamente:
DATABASE_URL="postgresql://postgres:<PASSWORD>@<PRIVATE_DOMAIN>:5432/railway"
DATABASE_PUBLIC_URL="postgresql://postgres:<PASSWORD>@<TCP_PROXY_DOMAIN>:<PORT>/railway"

PGDATABASE="railway"
PGHOST="<RAILWAY_PRIVATE_DOMAIN>"
PGPASSWORD="<POSTGRES_PASSWORD>"
PGPORT="5432"
PGUSER="postgres"

# ─── SSL (solo en fallback local sin Railway) ──────────────────────────────────
DB_SSLMODE=disable

# ─── Aplicación ────────────────────────────────────────────────────────────────
APP_ENV=development
PORT=8080

# ─── Autenticación (Better Auth Bridge) ───────────────────────────────────────
NEXTJS_URL=http://localhost:3000

# ─── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
