# ─── Base de Datos PostgreSQL ──────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=tu_password_aqui
DB_NAME=nei_db
DB_PORT=5432
DB_SSLMODE=disable

# ─── Aplicación ────────────────────────────────────────────────────────────────
APP_ENV=development
PORT=8080

# ─── Autenticación (Better Auth Bridge) ───────────────────────────────────────
# URL del servidor Next.js para validar sesiones
NEXTJS_URL=http://localhost:3000

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Origen permitido (tu dominio de Next.js)
FRONTEND_URL=http://localhost:3000
